# Home Lab Deployment Configuration
# Copy to .env and configure with your actual values

# Default SSH target for deployment (user@hostname or user@ip)
DEPLOY_TARGET=user@hostname

# SSH key path (optional, defaults to ~/.ssh/id_rsa)
# DEPLOY_SSH_KEY=~/.ssh/id_rsa

# Deployment directory on remote server (relative to home directory)
DEPLOY_DIR=aprs-station-map

# Application port
DEPLOY_PORT=80

# Application name
APP_NAME=aprs-station-map

# Runtime APRS / Direwolf configuration
STATION_CALLSIGN=YOURCALL-10
# Decimal degrees for your station location
STATION_LATITUDE=0.0000
STATION_LONGITUDE=0.0000

# Audio source: rtl-sdr, soundcard, or null
AUDIO_SOURCE=rtl-sdr
# RTL-SDR settings (used when AUDIO_SOURCE=rtl-sdr)
RTL_FREQ=144.8M
RTL_GAIN=30
RTL_PPM=0

# APRS-IS internet gating (optional)
# When set, Direwolf will relay received RF packets to the APRS-IS network.
# Leave APRS_IS_PASSCODE empty to disable igating.
# Generate your passcode at: https://apps.magicbug.co.uk/passcode/
APRS_IS_SERVER=rotate.aprs2.net
APRS_IS_PORT=14580
APRS_IS_PASSCODE=

# Target presets (optional - used with --target flag)
# Production Pi target
# DEPLOY_TARGET_PI=user@pi-hostname
# DEPLOY_DIR_PI=aprs-station-map
# DEPLOY_PORT_PI=80

# Home lab test target
# DEPLOY_TARGET_LAB=user@lab-hostname
# DEPLOY_DIR_LAB=aprs-station-map
# DEPLOY_PORT_LAB=8001
