# APRS Station Map — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.
#
# Two modes:
#   kiss    — local RTL-SDR/Direwolf/TNC (requires hardware)
#   aprs-is — internet-only, no hardware needed (passcode -1 = read-only)

# ── Mode ──────────────────────────────────────────────────────────────────────
DATA_SOURCE=aprs-is

# ── Station identity ───────────────────────────────────────────────────────────
# Your licensed callsign with SSID, e.g. M0LHA-10
# For read-only APRS-IS mode you can use NOCALL
STATION_CALLSIGN=NOCALL
STATION_LATITUDE=51.5074
STATION_LONGITUDE=-0.1278

# ── APRS-IS mode (DATA_SOURCE=aprs-is) ────────────────────────────────────────
APRS_IS_SERVER=rotate.aprs2.net
APRS_IS_PORT=14580
# Passcode: use -1 for read-only (no callsign needed), or your licensed passcode
# Generate at: https://apps.magicbug.co.uk/passcode/
APRS_IS_PASSCODE=-1
# Radius filter — highly recommended to limit traffic volume
# Format: r/LAT/LON/RADIUS_KM
APRS_IS_FILTER=r/51.5/-0.1/200

# ── KISS / Direwolf mode (DATA_SOURCE=kiss) ────────────────────────────────────
# Audio source: rtl-sdr, soundcard, or null
AUDIO_SOURCE=rtl-sdr
RTL_FREQ=144.8M
RTL_GAIN=30
RTL_PPM=0
# Set APRS_IS_PASSCODE above to enable igating (RF→internet relay)

# ── Application port (local Docker deployments) ────────────────────────────────
DEPLOY_PORT=80
